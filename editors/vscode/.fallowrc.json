{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/extension.ts",
    "src/types.ts",
    "src/generated/output-contract.d.ts"
  ],
  "ignorePatterns": [
    "test/integration/fixtures/**"
  ],
  "ignoreDependencies": ["@vscode/vsce"],
  "ignoreUnresolvedImports": [
    "./generated/output-contract.js",
    "../src/generated/output-contract.js"
  ],
  "ignoreExports": [
    {
      "file": "src/types.ts",
      "exports": ["*"]
    },
    {
      "file": "src/workspacePicker.ts",
      "exports": [
        "CLEAR_WORKSPACE_SCOPE",
        "WORKSPACE_STATE_KEY",
        "getWorkspaceStateOverride",
        "resolveWorkspaceScope"
      ]
    }
  ],
  "rules": {
    "unlisted-dependencies": "warn",
    "unresolved-imports": "warn"
  }
}
